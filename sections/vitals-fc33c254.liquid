{% style %}
:root {
--vtl-neutral-100: #222;
--vtl-neutral-70: #5e5e5e;
--vtl-neutral-01: #fff;
--vtl-size-2: 2px;
--vtl-size-4: 4px;
--vtl-size-8: 8px;
--vtl-size-14: 14px;
--vtl-size-16: 16px;
--vtl-size-20: 20px;
--vtl-size-24: 24px;
--vtl-size-32: 32px;
--vtl-size-40: 40px;
