<!-- --VERSION-15-- -->

{% style %}
:root {
--vtl-neutral-70: #5e5e5e;
--vtl-neutral-01: #fff;
--vtl-size-2: 2px;
--vtl-size-8: 8px;
--vtl-size-14: 14px;
--vtl-size-16: 16px;
--vtl-size-20: 20px;
--vtl-size-24: 24px;
--vtl-size-32: 32px;
--vtl-size-40: 40px;
--vtl-size-64: 64px;
--vtl-font-weight-400: 400;
--vtl-font-weight-600: 600;
--vtl-line-height-140: 1.4;
--vtl-color-bg-fill-inverse-on-light: var(--vtl-neutral-01);
--vtl-color-text-disable-on-light: var(--vtl-neutral-70);
--vtl-space-2: var(--vtl-size-2);
--vtl-space-8: var(--vtl-size-8);
--vtl-space-16: var(--vtl-size-16);
--vtl-space-20: var(--vtl-size-20);
--vtl-space-24: var(--vtl-size-24);
--vtl-space-32: var(--vtl-size-32);
--vtl-space-40: var(--vtl-size-40);
--vtl-space-64: var(--vtl-size-64);
--vtl-font-size-14: var(--vtl-size-14);
}


{% endstyle %}

<!-- --UUID-43e1018c-- -->

<section class="Vtls-{{ section.id | handle }} VtlsValueIconsImage {% if section.settings.section_width == 100 %}VtlsValueIconsImage--fullWidth{% endif %}">
	{% liquid
		assign loading = "lazy"
		assign fetchpriority = "auto"
		assign preload = false
		assign desktop_image_width = section.settings.section_width | times: 50 | divided_by: 100
		assign image_sizes = "(min-width: 992px) " | append: desktop_image_width | append: "vw, 100vw"
		assign icon_sizes = section.settings.icon_size | append: "px"

		if section.index == 1
			assign loading = "eager"
			assign fetchpriority = "high"
			assign preload = true
		endif
	%}
	<div
		class="
			VtlsValueIconsImageContainer
			{% if section.settings.background_image == blank and section.settings.section_background_style == 'image' %}VtlsValueIconsImageContainer--emptyImage{% endif %}
			VtlsValueIconsImageContainer--backgroundStyle-{{ section.settings.section_background_style }}
			VtlsValueIconsImageContainer--mobileImagePosition-{{ section.settings.position_on_mobile}}
			{% if section.settings.section_background_style == "gradient" and section.settings.enable_animation == true %}VtlsValueIconsImageContainer--hasAnimation{% endif %}
		"
	> 
		{%- if section.settings.section_background_style == 'image' -%}
			<div class="VtlsValueIconsImageContainer__BackgroundMedia" aria-hidden="true">
				{%- if section.settings.background_image != blank -%}
					{{-
						section.settings.background_image
						| image_url: width: section.settings.background_image.width
						| image_tag:
							sizes: '100vw',
							widths: '400, 600, 800, 1200, 1600, 1800, 2400, 2800, 3200',
							class: 'VtlsValueIconsImageContainer__BackgroundMediaImage',
							loading: loading,
							fetchpriority: fetchpriority,
							preload: preload
					-}}
				{%- else -%}
					<img
						src="data:image/webp;base64,"
						alt=""
						sizes="100vw"
						class="VtlsValueIconsImageContainer__BackgroundImage-placeholder"
					>
				{%- endif -%}
				<div class="VtlsValueIconsImageContainer__BackgroundOverlay"></div>
			</div>
		{%- endif -%}
		{%- if section.settings.heading != blank -%}
			<h2
				class="
					VtlsValueIconsImageHeading
					VtlsValueIconsImageHeading--alignment-{{ section.settings.heading_alignment }}
					VtlsValueIconsImageHeading--style-{{ section.settings.heading_style }}
				"
			>
				{{ section.settings.heading }}
			</h2>
		{%- endif -%}
		{%- if section.settings.icons_mobile_layout == "slider" -%}
			{%- if section.settings.image != blank -%}
				<div
					class="
						VtlsValueImageBlock
						VtlsValueImageBlock--sliderLayout
						VtlsValueImageBlock--aspectRatio-{{ section.settings.image_aspect_ratio }}
					"
				>
					{{-
						section.settings.image
						| image_url: width: section.settings.image.width
						| image_tag:
							sizes: image_sizes,
							widths: "400, 600, 800, 1200, 1600, 1800, 2400, 2800, 3200",
							fetchpriority: fetchpriority,
							loading: loading,
							preload: preload,
							class: "VtlsValueImageBlockImage"
					-}}
				</div>
			{%- else -%}
				<div
					class="
						VtlsValueImageBlock
						VtlsValueImageBlock--sliderLayout
						VtlsValueImageBlock--aspectRatio-{{ section.settings.image_aspect_ratio }}
					"
				>
					<img
						src="data:image/webp;base64,"
						alt="Image with an abstract figure"
						width="1008"
						height="1008"
						class="VtlsValueIconsBlock__IconDefault"
					>
				</div>
			{%- endif -%}
		{%- endif -%}
		<ul
			class="
				VtlsValueIconsImageList
				VtlsValueIconsImageList--mobileLayout-{{ section.settings.icons_mobile_layout }}
				VtlsValueIconsImageList--desktopImagePosition-{{ section.settings.position_on_desktop }}
				VtlsValueIconsImageList--mobileImagePosition-{{ section.settings.position_on_mobile}}
				{% if section.blocks.size <= 2 %}VtlsValueIconsImageList--blocksSize-two{% endif %}
			"
		>
			{%- if section.settings.image != blank -%}
				<li
					class="
						VtlsValueImageBlock
						VtlsValueImageBlock--imageSize-{{ section.settings.image_size }}
						VtlsValueImageBlock--aspectRatio-{{ section.settings.image_aspect_ratio }}
					"
				>
					{{-
						section.settings.image
						| image_url: width: section.settings.image.width
						| image_tag:
							sizes: image_sizes,
							widths: "400, 600, 800, 1200, 1600, 1800, 2400, 2800, 3200",
							fetchpriority: fetchpriority,
							loading: loading,
							preload: preload,
							class: "VtlsValueImageBlockImage"
					-}}
				</li>
			{%- else -%}
				<li
					class="
						VtlsValueImageBlock
						VtlsValueImageBlock--imageSize-{{ section.settings.image_size }}
						VtlsValueImageBlock--aspectRatio-{{ section.settings.image_aspect_ratio }}
					"
				>
					<img
						src="data:image/webp;base64,"
						alt="Image with an abstract figure"
						width="1008"
						height="1008"
						class="VtlsValueIconsBlock__IconDefault"
					>
				</li>
			{%- endif -%}
