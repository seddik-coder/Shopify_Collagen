{% style %}
	.Vtls-{{ section.id | handle }} {
		--section-margin-top: {{- section.settings.margin_top -}}px;
	  --section-margin-bottom: {{- section.settings.margin_bottom -}}px;
	  --section-margin-top-mobile: {{- section.settings.margin_top_mobile -}}px;
	  --section-margin-bottom-mobile: {{- section.settings.margin_bottom_mobile -}}px;
	  --section-padding-top: {{- section.settings.padding_top -}}px;
	  --section-padding-bottom: {{- section.settings.padding_bottom -}}px;
	  --section-padding-top-mobile: {{- section.settings.padding_top_mobile -}}px;
	  --section-padding-bottom-mobile: {{- section.settings.padding_bottom_mobile -}}px;
		--section-max-width: {{- section.settings.section_max_width -}}px;
		--section-width: {{- section.settings.section_width -}}%;
		--section-background-color: {{- section.settings.section_background -}};
		--section-background-gradient: {{ section.settings.section_gradient }};
	   --section-image-corner-radius: {{- section.settings.image_corner_radius -}}px;

		--section-overlay-color: {{- section.settings.overlay_color -}};
		--section-overlay-opacity: {{- section.settings.overlay_opacity -}}%;

		--section-heading-alignment: {{ section.settings.heading_alignment }};
		--section-heading-color: {{ section.settings.heading_color }};
		--section-heading-size: {{ section.settings.heading_size }}px;

		--section-icon-color: {{- section.settings.icon_color -}};
		--section-icon-size: {{- section.settings.icon_size -}}px;
		--section-icon-title-size: {{- section.settings.icon_title_size -}}px;
		--section-icon-title-color: {{- section.settings.icon_title_color -}};
		--section-icon-description-size: {{- section.settings.icon_description_size -}}px;
