				{%- liquid
					assign heading = block.settings.icon_title
					assign description = block.settings.icon_description
					assign icon = block.settings.icon
					assign font_awesome = block.settings.font_awesome
					assign custom_icon = block.settings.custom_icon

					assign sibling_block = blank

					case forloop.index0
						when 0
							assign sibling_block = section.blocks[1]
						when 1
							assign sibling_block = section.blocks[0]
						when 2
							assign sibling_block = section.blocks[3]
						when 3
							assign sibling_block = section.blocks[2]
					endcase

					assign sibling_block_description = sibling_block.settings.icon_description | strip_html | escape
					assign largest_description = description | strip_html | escape

					assign sibling_block_title = sibling_block.settings.icon_title | strip_html | escape
					assign largest_title = heading | strip_html | escape

					if sibling_block_description.size > largest_description.size
						assign largest_description = sibling_block_description
					endif

					if sibling_block_title.size > largest_title.size
						assign largest_title = sibling_block_title
					endif
				-%}

				<li
					class="VtlsValueIconsBlock"
					{{ block.shopify_attributes }}
				>
					<div class="VtlsValueIconsBlock__IconWrapper">
						{%- if font_awesome != blank and block.settings.icon_type == 'icon' -%}
							{% unless content_for_header contains "font-awesome" %}
								<link
									rel="stylesheet"
									href="https://use.fontawesome.com/releases/v5.15.4/css/all.css"
									integrity="sha384-DyZ88mC6Up2uqS4h/KRgHuoeGwBcD4Ng9SiP4dIRy0EXTlnuz47vAwmeGwVChigm"
									crossorigin="anonymous"
								>
							{% endunless %}
							<div class="VtlsValueIconsBlock__Icon">
								{{ font_awesome }}
							</div>
						{%- elsif icon != "none" and block.settings.icon_type == 'icon'-%}
							<div class="VtlsValueIconsBlock__Icon">
								{{ vtls_icon }}
							</div>
						{%- elsif custom_icon != blank and block.settings.icon_type == 'upload' -%}
							<div class="VtlsValueIconsBlock__Icon">
								{{-
									custom_icon
									| image_url: width: custom_icon.width
									| image_tag:
										sizes: icon_sizes,
										widths: "30, 40, 60, 80, 100, 200, 400, 600",
										fetchpriority: fetchpriority,
										loading: loading,
										preload: preload
								-}}
							</div>
						{%- else -%}
							<div class="VtlsValueIconsBlock__Icon">
								<img
									src="data:image/webp;base64,"
									alt="Image with an abstract figure"
									class="VtlsValueIconsBlock__IconDefault"
									width="520"
									height="520"
								>
							</div>
						{%- endif -%}
					</div>
					<div class="VtlsValueIconsBlock__TextContent">
						<h5 class="VtlsValueIconsBlock__Heading VtlsValueIconsBlock__Heading--VtlsInvisible">
							{{- largest_title -}}
						</h5>
						<p class="VtlsValueIconsBlock__Description VtlsValueIconsBlock__Description--VtlsInvisible">
							{{- largest_description -}}
						</p>
						<div class="VtlsValueIconsBlock__TextContentWrapper">
							{%- if heading != blank -%}
								<h5 class="VtlsValueIconsBlock__Heading">
									{{- heading -}}
								</h5>
							{%- endif -%}
							{%- if description != blank -%}
								<p class="VtlsValueIconsBlock__Description">
									{{- description -}}
								</p>
							{%- endif -%}
						</div>
					</div>
				</li>
			{%- endfor -%}
		</ul>
	</div>
</section>

