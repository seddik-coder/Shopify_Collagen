    text-transform: uppercase;
    color: var(--gris);
    margin-top: 0.3rem;
  }

  .rgc-hero-right {
    position: relative;
    overflow: hidden;
    background: #EDE0D4;
    min-height: 500px;
  }

  .rgc-hero-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

