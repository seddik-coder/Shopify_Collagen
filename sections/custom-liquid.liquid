{% comment %} Red Ginseng Collagen — Landing Page v2 {% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  /* ── RESET & VARS ── */
  .rgc * { margin: 0; padding: 0; box-sizing: border-box; }

  .rgc {
    --rouge:   #8B1C1C;
    --rouge2:  #A52424;
    --creme:   #FAF7F2;
    --creme2:  #F2EDE5;
    --brun:    #2C1A0E;
    --brun2:   #3D2010;
    --or:      #C9943A;
    --or2:     #E8B84B;
    --gris:    #8A8580;
    --blanc:   #FFFFFF;
    font-family: 'DM Sans', sans-serif;
    background: var(--creme);
    color: var(--brun);
    overflow-x: hidden;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
  }

  /* ── ANNOUNCE BAR ── */
  .rgc-announce {
    background: var(--brun);
    color: var(--creme);
    text-align: center;
    padding: 0.6rem 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .rgc-announce span { color: var(--or2); margin: 0 0.5rem; }

  /* ── HERO ── */
  .rgc-hero {
    position: relative;
    height: 96vh;
    min-height: 580px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .rgc-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .rgc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, rgba(44,26,14,0.82) 0%, rgba(44,26,14,0.45) 55%, transparent 80%);
  }

  .rgc-hero-content {
    position: relative;
    z-index: 2;
    padding: 0 5vw;
    max-width: 680px;
  }

  .rgc-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.68rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--or2);
    margin-bottom: 1.6rem;
  }

  .rgc-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--or2);
    flex-shrink: 0;
  }

  .rgc-hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 5.5vw, 5.2rem);
    font-weight: 300;
    line-height: 1.05;
    color: var(--creme);
    margin-bottom: 1.6rem;
    letter-spacing: -0.015em;
  }

  .rgc-hero-title em {
    font-style: italic;
    color: var(--or2);
    display: block;
  }

  .rgc-hero-desc {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(250,247,242,0.78);
    max-width: 420px;
    margin-bottom: 2.8rem;
    font-weight: 300;
  }

  .rgc-hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .rgc-btn-primary {
    display: inline-block;
    background: var(--rouge);
    color: var(--creme) !important;
    text-decoration: none !important;
    padding: 1.1rem 2.8rem;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: background 0.25s, transform 0.2s;
    white-space: nowrap;
  }

  .rgc-btn-primary:hover {
    background: var(--rouge2);
    transform: translateY(-2px);
  }

  .rgc-hero-social {
    font-size: 0.75rem;
    color: rgba(250,247,242,0.55);
    letter-spacing: 0.05em;
  }

  .rgc-hero-social strong {
    color: var(--creme);
    display: block;
    font-size: 1.1rem;
    font-weight: 500;
    line-height: 1;
    margin-bottom: 0.2rem;
  }

  /* ── TRUST STRIP ── */
  .rgc-trust {
    background: var(--brun);
    padding: 1.4rem 5vw;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .rgc-trust-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: rgba(250,247,242,0.75);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .rgc-trust-item svg {
    width: 18px;
    height: 18px;
    color: var(--or);
    flex-shrink: 0;
  }

  .rgc-trust-sep {
    width: 1px;
    height: 24px;
    background: rgba(250,247,242,0.15);
  }

  /* ── SECTION INTRO ── */
  .rgc-section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--or);
    margin-bottom: 1.2rem;
  }

  .rgc-section-label::before {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background: var(--or);
  }

  /* ── SPOON REVEAL SECTION ── */
  .rgc-reveal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 580px;
  }

  .rgc-reveal-img {
    position: relative;
    overflow: hidden;
    background: #e8ddd4;
  }

  .rgc-reveal-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s ease;
  }

  .rgc-reveal-img:hover img { transform: scale(1.03); }

  .rgc-reveal-text {
    background: var(--creme2);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 4.5rem;
  }

  .rgc-reveal-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--brun);
    margin-bottom: 1.4rem;
  }

  .rgc-reveal-title em {
    font-style: italic;
    color: var(--rouge);
  }

  .rgc-reveal-desc {
    font-size: 0.9rem;
    line-height: 1.85;
    color: var(--brun);
    opacity: 0.65;
    margin-bottom: 2.5rem;
    max-width: 380px;
  }

  .rgc-steps {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rgc-step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .rgc-step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--rouge);
    color: var(--creme);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.68rem;
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .rgc-step-body strong {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--brun);
    margin-bottom: 0.2rem;
    letter-spacing: 0.03em;
  }

  .rgc-step-body span {
    font-size: 0.78rem;
    color: var(--brun);
    opacity: 0.55;
    line-height: 1.6;
  }

  /* ── BENEFITS FULL-WIDTH IMAGE ── */
  .rgc-benefits-img {
    width: 100%;
    display: block;
    max-height: 560px;
    object-fit: cover;
    object-position: center;
  }

  /* ── BENEFITS CARDS BELOW ── */
  .rgc-benefits-cards {
    background: var(--brun);
    padding: 5rem 5vw;
  }

  .rgc-benefits-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .rgc-benefits-header .rgc-section-label {
    justify-content: center;
  }

  .rgc-benefits-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    color: var(--creme);
    line-height: 1.15;
  }

  .rgc-benefits-heading em {
    font-style: italic;
    color: var(--or2);
  }

  .rgc-benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(250,247,242,0.08);
    border: 1px solid rgba(250,247,242,0.08);
  }

  .rgc-benefit-card {
    background: var(--brun);
    padding: 2.5rem 2rem;
    transition: background 0.25s;
    position: relative;
  }

  .rgc-benefit-card:hover { background: rgba(250,247,242,0.04); }

  .rgc-benefit-icon {
    font-size: 1.8rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .rgc-benefit-num {
    position: absolute;
    top: 1.5rem;
    right: 1.8rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    font-weight: 300;
    color: rgba(201,148,58,0.15);
    line-height: 1;
  }

  .rgc-benefit-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--creme);
    margin-bottom: 0.6rem;
  }

  .rgc-benefit-desc {
    font-size: 0.8rem;
    line-height: 1.75;
    color: rgba(250,247,242,0.48);
  }

  /* ── INGREDIENTS ── */
  .rgc-ingredients {
    padding: 6rem 5vw;
    background: var(--creme);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .rgc-ing-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300;
    color: var(--brun);
    line-height: 1.15;
    margin-bottom: 1.4rem;
  }

  .rgc-ing-title em {
    font-style: italic;
    color: var(--rouge);
  }

  .rgc-ing-desc {
    font-size: 0.88rem;
    line-height: 1.9;
    color: var(--brun);
    opacity: 0.6;
    margin-bottom: 2.5rem;
  }

  .rgc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .rgc-tag {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.45rem 1rem;
    border: 0.5px solid rgba(61,32,16,0.22);
    color: var(--brun2);
    opacity: 0.8;
  }

  .rgc-stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(61,32,16,0.08);
  }

  .rgc-stat {
    background: var(--creme);
    padding: 1.8rem;
    text-align: center;
  }

  .rgc-stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.6rem;
    font-weight: 400;
    color: var(--rouge);
    display: block;
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .rgc-stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gris);
  }

  /* ── WIDE BANNER ── */
  .rgc-wide-banner {
    position: relative;
    height: 480px;
    overflow: hidden;
  }

  .rgc-wide-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .rgc-wide-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(44,26,14,0.72) 0%, rgba(44,26,14,0.15) 60%, transparent 85%);
    display: flex;
    align-items: center;
    padding: 0 5vw;
  }

  .rgc-wide-banner-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    font-weight: 300;
    color: var(--creme);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .rgc-wide-banner-title em {
    font-style: italic;
    color: var(--or2);
  }

  .rgc-wide-banner-sub {
    font-size: 0.9rem;
    color: rgba(250,247,242,0.68);
    margin-bottom: 2rem;
    max-width: 380px;
    line-height: 1.7;
  }

  /* ── TESTIMONIALS ── */
  .rgc-testimonials {
    padding: 6rem 5vw;
    background: var(--creme2);
  }

  .rgc-testimonials-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .rgc-testimonials-header .rgc-section-label {
    justify-content: center;
  }

  .rgc-testimonials-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 300;
    color: var(--brun);
    margin-bottom: 0.5rem;
  }

  .rgc-testimonials-sub {
    font-size: 0.8rem;
    color: var(--gris);
    letter-spacing: 0.05em;
  }

  .rgc-testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .rgc-testimonial-card {
    background: var(--blanc);
    padding: 2.2rem;
    border-bottom: 3px solid var(--rouge);
    position: relative;
  }

  .rgc-test-stars {
    color: var(--or);
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    margin-bottom: 1.2rem;
  }

  .rgc-test-quote {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    font-style: italic;
    font-weight: 300;
    color: var(--brun2);
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  .rgc-test-author {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .rgc-test-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--rouge);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--creme);
    font-size: 0.75rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .rgc-test-name {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--brun);
    letter-spacing: 0.04em;
  }

  .rgc-test-location {
    font-size: 0.7rem;
    color: var(--gris);
    margin-top: 0.15rem;
  }

  .rgc-verified {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2E7D32;
    background: #E8F5E9;
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
  }

  /* ── FAQ ── */
  .rgc-faq {
    padding: 6rem 5vw;
    background: var(--creme);
    max-width: 820px;
    margin: 0 auto;
  }

  .rgc-faq-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .rgc-faq-header .rgc-section-label {
    justify-content: center;
  }

  .rgc-faq-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 300;
    color: var(--brun);
  }

  .rgc-faq-item {
    border-bottom: 0.5px solid rgba(61,32,16,0.15);
    overflow: hidden;
  }

  .rgc-faq-q {
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    padding: 1.5rem 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--brun);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .rgc-faq-q:hover { color: var(--rouge); }

  .rgc-faq-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    position: relative;
  }

  .rgc-faq-icon::before,
  .rgc-faq-icon::after {
    content: '';
    position: absolute;
    background: var(--rouge);
    top: 50%;
    left: 50%;
    transition: transform 0.3s;
  }

  .rgc-faq-icon::before {
    width: 14px;
    height: 1.5px;
    transform: translate(-50%, -50%);
  }

  .rgc-faq-icon::after {
    width: 1.5px;
    height: 14px;
    transform: translate(-50%, -50%);
  }

  .rgc-faq-item.open .rgc-faq-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
    opacity: 0;
  }

  .rgc-faq-a {
    font-size: 0.85rem;
    line-height: 1.85;
    color: var(--brun);
    opacity: 0.6;
    padding: 0 0 1.5rem 0;
    display: none;
  }

  .rgc-faq-item.open .rgc-faq-a { display: block; }

  /* ── CTA FINAL ── */
  .rgc-cta-final {
    background: var(--rouge);
    padding: 7rem 5vw;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .rgc-cta-final::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Ccircle cx='30' cy='30' r='20'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }

  .rgc-cta-final > * { position: relative; z-index: 1; }

  .rgc-cta-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(250,247,242,0.5);
    margin-bottom: 1.5rem;
  }

  .rgc-cta-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4.2rem);
    font-weight: 300;
    color: var(--creme);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .rgc-cta-title em {
    font-style: italic;
    color: var(--or2);
  }

  .rgc-cta-sub {
    font-size: 0.9rem;
    color: rgba(250,247,242,0.65);
    margin-bottom: 2.8rem;
    line-height: 1.7;
  }

  .rgc-btn-cta {
    display: inline-block;
    background: var(--creme);
    color: var(--rouge) !important;
    text-decoration: none !important;
    padding: 1.2rem 3.5rem;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: all 0.25s;
    margin-bottom: 1.5rem;
  }

  .rgc-btn-cta:hover {
    background: var(--brun);
    color: var(--creme) !important;
    transform: translateY(-2px);
  }

  .rgc-cta-guarantee {
    font-size: 0.72rem;
    color: rgba(250,247,242,0.45);
    letter-spacing: 0.05em;
  }

  /* ── ANIMATIONS ── */
  .rgc-fade {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .rgc-fade.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .rgc-fade-delay-1 { transition-delay: 0.1s; }
  .rgc-fade-delay-2 { transition-delay: 0.2s; }
  .rgc-fade-delay-3 { transition-delay: 0.3s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .rgc-benefits-grid { grid-template-columns: repeat(2, 1fr); }
    .rgc-testimonials-grid { grid-template-columns: 1fr; gap: 1rem; }
    .rgc-ingredients { grid-template-columns: 1fr; gap: 3rem; padding: 4rem 5vw; }
    .rgc-reveal { grid-template-columns: 1fr; }
    .rgc-reveal-text { padding: 3.5rem 5vw; }
    .rgc-reveal-img { min-height: 320px; }
  }

  @media (max-width: 600px) {
    .rgc-hero { height: 100svh; }
    .rgc-hero-title { font-size: 2.6rem; }
    .rgc-benefits-grid { grid-template-columns: 1fr; }
    .rgc-trust { gap: 1rem; padding: 1rem 5vw; }
    .rgc-trust-sep { display: none; }
    .rgc-wide-banner { height: 300px; }
    .rgc-faq { padding: 4rem 5vw; }
    .rgc-cta-final { padding: 5rem 5vw; }
    .rgc-testimonials { padding: 4rem 5vw; }
    .rgc-benefits-cards { padding: 4rem 5vw; }
  }
</style>

<div class="rgc">

  {%- comment -%} ANNOUNCE BAR {%- endcomment -%}
  <div class="rgc-announce">
    🚚 Livraison aux Émirats Arabes Unis
    <span>·</span>
    Qualité certifiée Corée
    <span>·</span>
    Paiement sécurisé
  </div>

  {%- comment -%} HERO {%- endcomment -%}
  <section class="rgc-hero">
    <img
      class="rgc-hero-bg"
      src="https://cdn.shopify.com/s/files/1/0782/4159/5618/files/homepage3.jpg"
      alt="Red Ginseng Collagen Jelly — Énergie & Beauté au Quotidien"
      loading="eager"
      fetchpriority="high"
