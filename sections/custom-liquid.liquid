<style>
  .rgc * { margin: 0; padding: 0; box-sizing: border-box; }

  .rgc {
    --rouge:  #8B1C1C;
    --creme:  #FAF7F2;
    --brun:   #2C1A0E;
    --or:     #C9943A;
    --gris:   #8A8580;
    --line:   rgba(44,26,14,0.10);
    font-family: 'DM Sans', sans-serif;
    color: var(--brun);
    background: var(--creme);
    line-height: 1.6;
    overflow: hidden; /* contient les marges négatives full-bleed */
  }

  /* full-bleed sûr (pas de 100vw → pas de scrollbar fantôme) */
  .rgc-bleed {
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    width: 100vw;
    max-width: 100vw;
  }

  .rgc img { display: block; max-width: 100%; }

  /* ── TYPO ── */
  .rgc-serif { font-family: 'Cormorant Garamond', serif; font-weight: 300; }
  .rgc-eyebrow {
    font-size: 0.66rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--or);
    margin-bottom: 1.1rem;
  }

  /* ── BOUTONS ── */
  .rgc-btn {
    display: inline-block;
    padding: 1rem 2.6rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .25s, color .25s, transform .2s;
  }
  .rgc-btn--red   { background: var(--rouge); color: var(--creme); }
  .rgc-btn--red:hover   { background: var(--brun); transform: translateY(-2px); }
  .rgc-btn--cream { background: var(--creme); color: var(--rouge); }
  .rgc-btn--cream:hover { background: var(--brun); color: var(--creme); transform: translateY(-2px); }
  .rgc-btn--line  { background: transparent; color: var(--brun); border: 1px solid var(--brun); }
  .rgc-btn--line:hover { background: var(--brun); color: var(--creme); }

  /* ── ANNOUNCE ── */
  .rgc-announce {
    background: var(--brun);
    color: var(--creme);
    text-align: center;
    padding: 0.7rem 1rem;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* ── HERO (image avec texte intégré, affichée nette) ── */
  .rgc-hero { position: relative; }
  .rgc-hero img { width: 100%; height: auto; }
  .rgc-hero-cta {
    text-align: center;
    background: var(--creme);
    padding: 2.5rem 1.5rem 3rem;
  }
  .rgc-hero-cta .rgc-stars { color: var(--or); letter-spacing: 0.2em; font-size: 0.9rem; margin-bottom: 0.5rem; }
  .rgc-hero-cta .rgc-note { font-size: 0.72rem; color: var(--gris); margin-bottom: 1.6rem; letter-spacing: 0.04em; }

  /* ── TRUST ── */
  .rgc-trust {
    background: var(--brun);
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 2.5rem;
    padding: 1.4rem 5vw;
  }
  .rgc-trust span {
    color: rgba(250,247,242,0.85);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* ── SECTION DE BASE ── */
  .rgc-section { padding: 6rem 8vw; }

  /* ── REVEAL (image + texte) ── */
  .rgc-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 0;
  }
  .rgc-split img { width: 100%; height: 100%; object-fit: cover; }
  .rgc-split-text { padding: 5rem 6vw; }
  .rgc-split-text h2 { font-size: clamp(2rem,3vw,2.7rem); line-height: 1.15; margin-bottom: 1.3rem; }
  .rgc-split-text h2 em { font-style: italic; color: var(--rouge); }
  .rgc-split-text p { font-size: 0.92rem; color: var(--brun); opacity: 0.7; margin-bottom: 2.2rem; max-width: 400px; }

  .rgc-steps { display: flex; flex-direction: column; gap: 1.1rem; margin-bottom: 2.5rem; }
  .rgc-step { display: flex; gap: 1rem; align-items: flex-start; }
  .rgc-step b {
    flex-shrink: 0; width: 30px; height: 30px; border-radius: 50%;
    background: var(--rouge); color: var(--creme);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.72rem; font-weight: 600;
  }
  .rgc-step-t strong { display: block; font-size: 0.82rem; font-weight: 600; margin-bottom: 0.15rem; }
  .rgc-step-t span { font-size: 0.78rem; color: var(--brun); opacity: 0.6; }

  /* ── INGREDIENTS / STATS ── */
  .rgc-ingredients {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .rgc-ingredients h2 { font-size: clamp(2rem,3vw,2.7rem); line-height: 1.15; margin-bottom: 1.3rem; }
  .rgc-ingredients h2 em { font-style: italic; color: var(--rouge); }
  .rgc-ingredients p { font-size: 0.92rem; opacity: 0.7; margin-bottom: 2rem; }
  .rgc-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; }
  .rgc-tag {
    font-size: 0.64rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.45rem 1rem; border: 1px solid var(--line); color: var(--brun); opacity: 0.8;
  }
  .rgc-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--line); }
  .rgc-stat { background: var(--creme); padding: 2rem; text-align: center; }
  .rgc-stat b { font-family: 'Cormorant Garamond', serif; font-weight: 400; font-size: 2.6rem; color: var(--rouge); display: block; line-height: 1; margin-bottom: 0.4rem; }
  .rgc-stat span { font-size: 0.64rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gris); }

  /* ── BANNER pleine largeur (image nette) ── */
  .rgc-banner img { width: 100%; height: auto; }

  /* ── TESTIMONIALS épurés ── */
  .rgc-testi { text-align: center; background: #F2EDE5; }
  .rgc-testi h2 { font-size: clamp(1.8rem,3vw,2.4rem); margin-bottom: 0.4rem; }
  .rgc-testi-sub { font-size: 0.76rem; color: var(--gris); letter-spacing: 0.05em; margin-bottom: 3.5rem; }
  .rgc-testi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; text-align: left; }
  .rgc-card { background: #fff; padding: 2.2rem; }
  .rgc-card .rgc-stars { color: var(--or); font-size: 0.82rem; letter-spacing: 0.12em; margin-bottom: 1rem; }
  .rgc-card q { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.05rem; line-height: 1.6; display: block; margin-bottom: 1.3rem; }
  .rgc-card cite { font-style: normal; font-size: 0.74rem; font-weight: 600; }
  .rgc-card small { display: block; font-size: 0.68rem; color: var(--gris); margin-top: 0.1rem; }

  /* ── FAQ ── */
  .rgc-faq { max-width: 760px; margin: 0 auto; }
  .rgc-faq h2 { text-align: center; font-size: clamp(1.8rem,3vw,2.4rem); margin-bottom: 3rem; }
  .rgc-faq details { border-bottom: 1px solid var(--line); }
  .rgc-faq summary {
    list-style: none; cursor: pointer;
    padding: 1.4rem 0; font-size: 0.9rem; font-weight: 500;
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
  }
  .rgc-faq summary::-webkit-details-marker { display: none; }
  .rgc-faq summary::after { content: '+'; color: var(--rouge); font-size: 1.4rem; font-weight: 300; transition: transform .25s; }
  .rgc-faq details[open] summary::after { transform: rotate(45deg); }
  .rgc-faq p { font-size: 0.85rem; opacity: 0.7; line-height: 1.8; padding: 0 0 1.4rem; }

  /* ── CTA FINAL ── */
  .rgc-cta { background: var(--rouge); text-align: center; color: var(--creme); }
  .rgc-cta .rgc-eyebrow { color: rgba(250,247,242,0.5); }
  .rgc-cta h2 { font-size: clamp(2.4rem,4.5vw,3.8rem); line-height: 1.1; margin-bottom: 1rem; }
  .rgc-cta h2 em { font-style: italic; color: var(--or); }
  .rgc-cta p { font-size: 0.85rem; color: rgba(250,247,242,0.7); margin-bottom: 2.5rem; }
  .rgc-cta small { display: block; font-size: 0.68rem; color: rgba(250,247,242,0.45); margin-top: 1.5rem; letter-spacing: 0.04em; }

  /* ── ANIMATIONS ── */
  .rgc-fade { opacity: 0; transform: translateY(22px); transition: opacity .7s ease, transform .7s ease; }
  .rgc-fade.in { opacity: 1; transform: none; }

  /* ── RESPONSIVE ── */
  @media (max-width: 989px) {
    .rgc-testi-grid { grid-template-columns: 1fr; }
    .rgc-split { grid-template-columns: 1fr; }
    .rgc-split-img { min-height: 320px; }
    .rgc-ingredients { grid-template-columns: 1fr; gap: 3rem; }
    .rgc-section { padding: 4.5rem 6vw; }
  }
  @media (max-width: 749px) {
    .rgc-split-text { padding: 3.5rem 6vw; }
    .rgc-trust { gap: 1.2rem 2rem; padding: 1.2rem 6vw; }
    .rgc-section { padding: 4rem 6vw; }
  }
</style>

