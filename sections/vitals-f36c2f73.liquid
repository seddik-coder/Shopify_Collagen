{%- liquid
	assign loading = "lazy"
	assign fetchpriority = "auto"
	assign preload = false
	assign products_per_row_desktop = section.settings.products_per_row_desktop | plus: 0
	assign products_per_row_mobile = section.settings.products_per_row_mobile | plus: 0
	assign eager_products_limit = products_per_row_desktop | times: 2
	assign desktop_image_width = section.settings.section_width | divided_by: products_per_row_desktop
	assign mobile_image_width = 100 | divided_by: products_per_row_mobile
	assign sizes = "(min-width: 992px) " | append: desktop_image_width | append: "vw, " | append: mobile_image_width | append: "vw"

	if section.index == 1
		assign loading = "eager"
		assign fetchpriority = "high"
		assign preload = true
	endif
-%}

<section
	class="
		Vtls-{{ section.id | handle }} VtlsFeaturedProductsGridSection
		 VtlsFeaturedProductsGridSection--backgroundStyle-{{ section.settings.section_background_style }}
		{% if section.settings.background_image == blank and section.settings.section_background_style == 'image' %}VtlsFeaturedProductsGridSection--emptyImage{% endif %}
	"
>
	{% for block in section.blocks %}
		{% case block.type %}
			{% when "heading" %}
				{% assign heading_block = block %}
			{% when "button" %}
				{% assign button_block = block %}
			{% when "products" %}
				{% assign products_block = block %}
		{% endcase %}
	{% endfor %}

		<div
			class="
				VtlsFeaturedProductsGrid
				{% if section.settings.section_width == 100 %}VtlsFeaturedProductsGrid--fullWidth{% endif %}
			"
		>
			{%- if heading_block.settings.heading != blank or heading_block.settings.description != blank -%}
			<div
				class="
					VtlsFeaturedProductsGridTextWrapper
					VtlsFeaturedProductsGridTextWrapper--alignment-{{ heading_block.settings.text_alignment }}
				"
			{{ heading_block.shopify_attributes }}
		>
			{%- if heading_block.settings.heading != blank -%}
				<h2
					class="
						VtlsFeaturedProductsGridTextWrapper__Heading
						VtlsFeaturedProductsGridTextWrapper__Heading--style-{{ heading_block.settings.heading_style }}
						VtlsFeaturedProductsGridTextWrapper__Heading--alignment-{{ heading_block.settings.text_alignment }}
					"
				>
					{{ heading_block.settings.heading }}
				</h2>
			{%- endif -%}
			{%- if heading_block.settings.description != blank -%}
				<div
					class="
						VtlsFeaturedProductsGridTextWrapper__Description
						VtlsFeaturedProductsGridTextWrapper__Heading--alignment-{{ heading_block.settings.text_alignment }}
					"
				>
					{{ heading_block.settings.description }}
				</div>
			{%- endif -%}
		</div>
		{%- endif -%}
		<div class="VtlsFeaturedProductsGridContent">
			<div class="VtlsFeaturedProductsGridContent__Products" {{ products_block.shopify_attributes }}>
					{% if products_block.settings.product_list.count > 0 %}
						{% for product in products_block.settings.product_list %}
							{%- liquid
								assign product_loading = loading
								assign product_fetchpriority = fetchpriority
								assign product_preload = preload
								if forloop.index > eager_products_limit
									assign product_loading = "lazy"
									assign product_fetchpriority = "auto"
									assign product_preload = false
								endif
							-%}
							<div class="VtlsProductsGridProdCard">
								<div class="VtlsProductsGridProdCard__Container">
									<vtls-product-image-carousel class="VtlsProductsGridProdCardImageContainer VtlsProductsGridProdCardImageContainer--{{ section.settings.image_aspect_ratio }} VtlsProductsGridProdCardImageContainer--slider">
										<a href="{{ product.url }}" class="VtlsProductsGridProdCardImageLink">
											{% for image in product.images %}
												{%- liquid
													assign image_loading = "lazy"
													assign image_fetchpriority = "auto"
													assign image_preload = false
													assign image_class = "VtlsProductsGridProdCardImage"
													if forloop.first
														assign image_loading = product_loading
														assign image_fetchpriority = product_fetchpriority
														assign image_preload = product_preload
														assign image_class = image_class | append: " VtlsActive"
													endif
												-%}
												{{-
													image
													| image_url: width: image.width
													| image_tag:
														sizes: sizes,
														widths: "400, 600, 800, 1200, 1600, 1800, 2400, 2800, 3200",
														loading: image_loading,
														fetchpriority: image_fetchpriority,
														preload: image_preload,
														class: image_class
												-}}
											{% endfor %}
										</a>
									{% if product.images.size > 1 %}
										<button
											class="VtlsProductsGridProdCardArrow VtlsProductsGridProdCardArrow--left"
											aria-label="Previous image"
										>
											<svg
												width="18"
												height="18"
												viewBox="0 0 18 18"
												fill="none"
												xmlns="http://www.w3.org/2000/svg"
											>
												<path d="M12.375 2.25L5.625 9L12.375 15.75" stroke="#222222" stroke-linecap="round" stroke-linejoin="round"/>
											</svg>
										</button>
										<button
											class="VtlsProductsGridProdCardArrow VtlsProductsGridProdCardArrow--right"
											aria-label="Next image"
										>
											<svg
												width="18"
												height="18"
												viewBox="0 0 18 18"
												fill="none"
												xmlns="http://www.w3.org/2000/svg"
											>
												<path d="M5.625 2.25L12.375 9L5.625 15.75" stroke="#222222" stroke-linecap="round" stroke-linejoin="round"/>
											</svg>
										</button>
									{% endif %}
								</vtls-product-image-carousel>
								<div class="VtlsProductsGridProdCardTextContainer">
									{% if section.settings.show_vendor %}
										<div class="VtlsProductsGridProdCardTextContainer__Vendor">
											{{ product.vendor }}
										</div>
									{% endif %}
									<p
										class="VtlsProductsGridProdCardTextContainer__ProductTitle"
										title="{{ product.title }}"
									>
										<a href="{{ product.url }}">{{ product.title }}</a>
									</p>
									<div class="VtlsProductsGridProdCardTextContainer__Prices">
										{% if product.compare_at_price %}
											<span class="VtlsProductsGridProdCardInitialPrice">
												{{- product.compare_at_price | money -}}
											</span>
										{% endif %}
										<span class="VtlsProductsGridProdCardPrice {% if product.compare_at_price %}price-with-red{% endif %}">
											{{ product.price | money }}
										</span>
									</div>
								</div>
							</div>
						</div>
					{% endfor %}
				{% endif %}

				{% comment %}  ***** This block is generated as sample to allow user changes until the products are added to the list ***** {% endcomment %}
				{% if products_block.settings.product_list.count == 0 %}
					{% for i in (1..8) %}
						<div class="VtlsProductsGridProdCard">
							<div class="VtlsProductsGridProdCard__Container">
								<div class="VtlsProductsGridProdCardImageContainer VtlsProductsGridProdCardImageContainer--{{ section.settings.image_aspect_ratio }}">
									<a href="{{ product.url }}">
											<img
												src="data:image/webp;base64,"
												alt="Image with an abstract figure"
												width="520"
												height="520"
												sizes="{{ sizes }}"
											>
									</a>
								</div>
								<div class="VtlsProductsGridProdCardTextContainer">
									{% if section.settings.show_vendor %}
										<div class="VtlsProductsGridProdCardTextContainer__Vendor">VENDOR</div>
									{% endif %}
									<p
										class="VtlsProductsGridProdCardTextContainer__ProductTitle"
										title="Product title"
									>
										<a href="{{ product.url }}">Product title</a>
									</p>
									<div class="VtlsProductsGridProdCardTextContainer__Prices">
										<span class="VtlsProductsGridProdCardPrice"> $270.00 </span>
									</div>
								</div>
							</div>
						</div>
					{% endfor %}
				{% endif %}
			</div>
			{%- if button_block.settings.primary_button_label != blank -%}
				<div
					class="VtlsFeaturedProductsGridContent__Button VtlsFeaturedProductsGridContent__Button--alignment-{{ button_block.settings.button_alignment }}"
					{{ button_block.shopify_attributes }}
				>
					<a
						{% if button_block.settings.primary_new_tab == true %}
							target="_blank"
						{% endif %}
						class="VtlsFeaturedProductsGridContent__Button--style-{{ button_block.settings.primary_button_style }}"
						href="{{ button_block.settings.primary_button_link }}"
					>
						{{- button_block.settings.primary_button_label | escape -}}
					</a>
				</div>
			{%- endif -%}
		</div>
	</div>
</section>

<script>
	if (!customElements.get('vtls-product-image-carousel')) {
		class VtlsProductImageCarousel extends HTMLElement {
			constructor() {
				super();
				this.currentIndex = 0;
				this.images = [];
				this.prevButton = null;
				this.nextButton = null;
			}

			connectedCallback() {
				requestAnimationFrame(() => {
					this.setProperties();
					this.showImage(this.currentIndex);
					this.setEventListeners();
				});
			}

			setProperties() {
				this.images = this.querySelectorAll('.VtlsProductsGridProdCardImage');
				this.prevButton = this.querySelector('.VtlsProductsGridProdCardArrow--left');
				this.nextButton = this.querySelector('.VtlsProductsGridProdCardArrow--right');
			}

			showImage(index) {
				this.images.forEach((img, i) => {
					img.classList.toggle('VtlsActive', i === index);
				});
			}

			prevImage(event) {
				event.preventDefault();
				event.stopPropagation();
				this.currentIndex = (this.currentIndex - 1 + this.images.length) % this.images.length;
				this.showImage(this.currentIndex);
			}

			nextImage(event) {
				event.preventDefault();
				event.stopPropagation();
				this.currentIndex = (this.currentIndex + 1) % this.images.length;
				this.showImage(this.currentIndex);
			}

			setEventListeners() {
				this.prevButton?.addEventListener('click', this.prevImage.bind(this));
				this.nextButton?.addEventListener('click', this.nextImage.bind(this));
			}
		}

		customElements.define('vtls-product-image-carousel', VtlsProductImageCarousel);
	}
</script>

