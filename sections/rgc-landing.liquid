<script>
(function () {
  var root = document.currentScript ? document.currentScript.parentElement : document.querySelector('.rgc');

  // FAQ accordion
  root.querySelectorAll('.rgc-faq details').forEach(function (d) {
    d.addEventListener('toggle', function () {
      if (d.open) root.querySelectorAll('.rgc-faq details').forEach(function (o) { if (o !== d) o.open = false; });
    });
  });

  // Variant selection — update sticky price + active state
  var variantBtns = root.querySelectorAll('.rgc-variant-btn');
  var stickyPrice = document.getElementById('rgcStickyPrice');
  var stickyLabel = document.getElementById('rgcStickyLabel');
  var orderBtn    = document.getElementById('rgc-order-btn');

  variantBtns.forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      variantBtns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      if (stickyPrice) stickyPrice.textContent = btn.dataset.price;
      if (stickyLabel) stickyLabel.textContent = btn.querySelector('.rgc-variant-name').textContent.trim();
      if (orderBtn)    orderBtn.href = btn.href;
    });
  });

  // Sticky bar — show after hero on mobile
  var heroEl = root.querySelector('.rgc-hero');
  window.addEventListener('scroll', function () {
    var bar = document.getElementById('rgcStickyBar');
    if (!bar) return;
    var threshold = heroEl ? heroEl.offsetHeight : 400;
    bar.style.display = (window.innerWidth <= 989 && window.scrollY > threshold) ? 'flex' : 'none';
  }, { passive: true });

  // Smooth scroll
  root.querySelectorAll('a[href^="#"]').forEach(function (a) {
    a.addEventListener('click', function (e) {
      var target = document.querySelector(a.getAttribute('href'));
      if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
    });
  });
})();
</script>

