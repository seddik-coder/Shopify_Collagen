<script>
(function () {
  var root = document.currentScript.previousElementSibling;
  if (!root) return;

  var faders = root.querySelectorAll('.rgc-fade');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    faders.forEach(function (el) { io.observe(el); });
  } else {
    faders.forEach(function (el) { el.classList.add('in'); });
  }

  var items = root.querySelectorAll('.rgc-faq details');
  items.forEach(function (d) {
    d.addEventListener('toggle', function () {
      if (d.open) items.forEach(function (o) { if (o !== d) o.open = false; });
    });
  });

  // Variant picker — update price and CTA link
  var variantBtns = document.querySelectorAll('#rgc-variant-picker .rgc-variant-btn');
  var priceEl = document.getElementById('rgc-price');
  var priceSubEl = document.getElementById('rgc-price-sub');
  var ctaBtn = document.getElementById('rgc-cta-btn');
  variantBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      variantBtns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      if (priceEl) priceEl.textContent = btn.dataset.price;
      if (priceSubEl) priceSubEl.textContent = btn.textContent.trim();
      if (ctaBtn) ctaBtn.href = btn.dataset.url;
    });
  });
})();
</script>

