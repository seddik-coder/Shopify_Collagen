<style>
.rgc * { margin: 0; padding: 0; box-sizing: border-box; }

.rgc {
  --rouge: #8B1C1C;
  --creme: #FAF7F2;
  --brun:  #2C1A0E;
  --or:    #C9943A;
  --gris:  #8A8580;
  --line:  rgba(44,26,14,0.10);
  font-family: 'DM Sans', sans-serif;
  color: var(--brun);
  background: var(--creme);
  line-height: 1.6;
  overflow-x: hidden;
}

.rgc img { display: block; max-width: 100%; }
.rgc-serif { font-family: 'Cormorant Garamond', serif; font-weight: 300; }
.rgc-eyebrow {
  font-size: 0.66rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--or);
  margin-bottom: 1rem;
}
.rgc-bleed {
  margin-left: calc(50% - 50vw);
  margin-right: calc(50% - 50vw);
  width: 100vw;
  max-width: 100vw;
}

/* ── TICKER ── */
.rgc-ticker {
  background: #F2EDE5;
  overflow: hidden;
  padding: 0.55rem 0;
  border-bottom: 1px solid var(--line);
}
.rgc-ticker-inner {
  display: flex;
  gap: 4rem;
  animation: rgcTicker 22s linear infinite;
  white-space: nowrap;
  width: max-content;
}
.rgc-ticker-inner span {
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--brun);
  opacity: 0.75;
}
@keyframes rgcTicker {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ── HERO ── */
.rgc-hero { position: relative; overflow: hidden; background: #EDE8E0; }
.rgc-hero img { width: 100%; height: auto; display: block; }
.rgc-hero-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding: 2.5rem;
  background: linear-gradient(to top, rgba(44,26,14,0.45) 0%, transparent 45%);
}
.rgc-scroll-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.68rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--creme);
  border-bottom: 1px solid rgba(250,247,242,0.5);
  padding-bottom: 0.2rem;
  text-decoration: none;
}

/* ── TRUST BAR ── */
.rgc-trust {
  background: var(--brun);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  gap: 2.5rem;
  padding: 1.4rem 5vw;
}
.rgc-trust span {
  color: rgba(250,247,242,0.85);
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  white-space: nowrap;
}

/* ── SECTIONS ── */
.rgc-section { padding: 5rem 8vw; }

/* ── BENEFITS ── */
.rgc-section-header {
  text-align: center;
  max-width: 560px;
  margin: 0 auto 3.5rem;
}
.rgc-section-header h2 { font-size: clamp(2rem,3vw,2.6rem); line-height: 1.15; }
.rgc-section-header h2 em { font-style: italic; color: var(--rouge); }
.rgc-section-header p { font-size: 0.88rem; opacity: 0.6; margin-top: 0.8rem; line-height: 1.7; }

.rgc-benefits-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 2px;
  background: var(--line);
}
.rgc-benefit-card { background: var(--creme); padding: 2.5rem 2rem; text-align: center; }
.rgc-benefit-icon { font-size: 2rem; margin-bottom: 1rem; display: block; }
.rgc-benefit-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; margin-bottom: 0.5rem; }
.rgc-benefit-card p { font-size: 0.78rem; opacity: 0.65; line-height: 1.7; }

/* ── SPLIT (ritual + order) ── */
.rgc-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: stretch;
}
.rgc-split-img { overflow: hidden; min-height: 420px; }
.rgc-split-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rgc-split-text {
  padding: 4rem 5vw;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.rgc-split-text h2 { font-size: clamp(1.8rem,2.5vw,2.4rem); line-height: 1.15; margin-bottom: 1rem; }
.rgc-split-text h2 em { font-style: italic; color: var(--rouge); }
.rgc-split-text > p { font-size: 0.86rem; opacity: 0.65; margin-bottom: 1.8rem; max-width: 380px; line-height: 1.8; }
.rgc-steps { display: flex; flex-direction: column; gap: 0.9rem; }
.rgc-step { display: flex; gap: 1rem; align-items: flex-start; }
.rgc-step-num {
  flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%;
  background: var(--rouge); color: white;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.68rem; font-weight: 600;
}
.rgc-step-body strong { display: block; font-size: 0.82rem; font-weight: 600; margin-bottom: 0.1rem; }
.rgc-step-body span { font-size: 0.75rem; opacity: 0.6; }

/* ── ORDER SECTION ── */
.rgc-order {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: stretch;
  background: #F2EDE5;
}
.rgc-order-img { overflow: hidden; min-height: 420px; }
.rgc-order-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rgc-order-content {
  padding: 4rem 4vw;
  display: flex;
  flex-direction: column;
  justify-content: center;
  max-width: 520px;
}
.rgc-order-content h2 { font-size: clamp(1.7rem,2.2vw,2.2rem); line-height: 1.15; margin-bottom: 0.3rem; }
.rgc-order-content h2 em { font-style: italic; color: var(--rouge); }
.rgc-order-tagline { font-size: 0.8rem; opacity: 0.6; margin-bottom: 1.6rem; }

.rgc-variant-label { font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gris); margin-bottom: 0.7rem; }
.rgc-variants { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.4rem; }
.rgc-variant-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1rem;
  border: 1.5px solid var(--line);
  background: white;
  cursor: pointer;
  transition: border-color .2s, background .2s;
  width: 100%;
  text-decoration: none;
}
.rgc-variant-btn.active,
.rgc-variant-btn:hover { border-color: var(--rouge); background: rgba(139,28,28,0.04); }
.rgc-variant-left { text-align: left; }
.rgc-variant-name { font-size: 0.8rem; font-weight: 500; color: var(--brun); }
.rgc-variant-badge {
  font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase;
  background: var(--or); color: white; padding: 0.18rem 0.55rem; margin-left: 0.5rem;
}
.rgc-variant-per { font-size: 0.63rem; color: var(--gris); margin-top: 0.15rem; }
.rgc-variant-price { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; color: var(--rouge); white-space: nowrap; }

.rgc-btn-primary {
  display: block;
  width: 100%;
  padding: 1.1rem;
  background: var(--rouge);
  color: var(--creme);
  text-align: center;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: background .25s, transform .2s;
  margin-bottom: 1rem;
}
.rgc-btn-primary:hover { background: var(--brun); color: var(--creme); transform: translateY(-1px); }

.rgc-order-trust { display: flex; gap: 1.2rem; flex-wrap: wrap; }
.rgc-order-trust span {
  font-size: 0.63rem; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--gris); display: flex; align-items: center; gap: 0.3rem;
}

/* ── INGREDIENTS ── */
.rgc-ingredients {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: center;
}
.rgc-ingredients h2 { font-size: clamp(2rem,2.8vw,2.6rem); line-height: 1.15; margin-bottom: 1.2rem; }
.rgc-ingredients h2 em { font-style: italic; color: var(--rouge); }
.rgc-ingredients > div > p { font-size: 0.88rem; opacity: 0.65; margin-bottom: 2rem; line-height: 1.8; }
.rgc-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.rgc-tag {
  font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 0.45rem 1rem; border: 1px solid var(--line); color: var(--brun); opacity: 0.8;
}
.rgc-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--line); }
.rgc-stat { background: var(--creme); padding: 1.8rem; text-align: center; }
.rgc-stat b { font-family: 'Cormorant Garamond', serif; font-size: 2.4rem; color: var(--rouge); display: block; line-height: 1; margin-bottom: 0.3rem; }
.rgc-stat span { font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gris); }

/* ── TESTIMONIALS ── */
.rgc-testi { background: #F2EDE5; text-align: center; }
.rgc-testi h2 { font-size: clamp(1.8rem,2.8vw,2.4rem); margin-bottom: 0.4rem; }
.rgc-testi-sub { font-size: 0.75rem; color: var(--gris); margin-bottom: 3.5rem; }
.rgc-testi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; text-align: left; }
.rgc-card { background: white; padding: 2rem; }
.rgc-card .rgc-stars { color: var(--or); font-size: 0.82rem; letter-spacing: 0.12em; margin-bottom: 0.8rem; }
.rgc-card q { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1rem; line-height: 1.6; display: block; margin-bottom: 1.2rem; }
.rgc-card cite { font-style: normal; font-size: 0.74rem; font-weight: 600; }
.rgc-card small { display: block; font-size: 0.66rem; color: var(--gris); margin-top: 0.1rem; }

/* ── GUARANTEE ── */
.rgc-guarantee-badge {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  border: 1.5px solid var(--or);
  padding: 3rem 3rem;
  width: 100%;
}
.rgc-guarantee-badge h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; }
.rgc-guarantee-badge p { font-size: 0.82rem; opacity: 0.65; line-height: 1.8; text-align: center; }

/* ── FAQ ── */
.rgc-faq details { border-bottom: 1px solid var(--line); }
.rgc-faq summary {
  list-style: none; cursor: pointer;
  padding: 1.4rem 0; font-size: 0.88rem; font-weight: 500;
  display: flex; justify-content: space-between; align-items: center; gap: 1rem;
}
.rgc-faq summary::-webkit-details-marker { display: none; }
.rgc-faq summary::after { content: '+'; color: var(--rouge); font-size: 1.4rem; font-weight: 300; transition: transform .25s; }
.rgc-faq details[open] summary::after { transform: rotate(45deg); }
.rgc-faq p { font-size: 0.84rem; opacity: 0.68; line-height: 1.8; padding: 0 0 1.4rem; }

/* ── STICKY BAR (mobile) ── */
.rgc-sticky {
  display: none;
  position: fixed;
  bottom: 0; left: 0; right: 0;
  z-index: 200;
  background: var(--creme);
  border-top: 1px solid var(--line);
  padding: 0.9rem 1.2rem;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
}
.rgc-sticky-info strong { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--rouge); display: block; line-height: 1; }
.rgc-sticky-info span { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gris); }
.rgc-sticky a {
  flex: 1; padding: 0.85rem; background: var(--rouge); color: white;
  text-align: center; font-size: 0.72rem; font-weight: 500;
  letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none;
}

/* ── RESPONSIVE ── */
@media (max-width: 989px) {
  .rgc-split { grid-template-columns: 1fr; }
  .rgc-split-img { min-height: 280px; }
  .rgc-split-text { padding: 3rem 5vw; }
  .rgc-order { grid-template-columns: 1fr; }
  .rgc-order-img { min-height: 280px; max-height: 340px; }
  .rgc-order-content { max-width: 100%; padding: 3rem 5vw; }
  .rgc-ingredients { grid-template-columns: 1fr; gap: 2.5rem; }
  .rgc-benefits-grid { grid-template-columns: 1fr 1fr; }
  .rgc-testi-grid { grid-template-columns: 1fr; }
  .rgc-section { padding: 4rem 5vw; }
  .rgc-sticky { display: flex; }
  .rgc-guarantee-faq { grid-template-columns: 1fr !important; gap: 3rem !important; }
}
@media (max-width: 749px) {
  .rgc-trust { gap: 0.7rem 1.2rem; padding: 1rem 5vw; }
  .rgc-trust span { font-size: 0.58rem; }
  .rgc-benefits-grid { grid-template-columns: 1fr; }
  .rgc-benefit-card { padding: 1.5rem 1.2rem; }
  .rgc-guarantee-badge { padding: 2rem 1.2rem; }
  .rgc-section-header h2, .rgc-split-text h2, .rgc-order-content h2,
  .rgc-ingredients h2, .rgc-testi h2 { font-size: 1.7rem; }
  .rgc-section { padding: 3rem 5vw; }
  .rgc-ticker-inner { animation-duration: 30s; }
}
</style>

