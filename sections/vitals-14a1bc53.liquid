<!-- --VERSION-8-- -->

{% style %}
:root {
--vtl-neutral-100: #222;
--vtl-neutral-70: #5e5e5e;
--vtl-neutral-01: #fff;
--vtl-size-2: 2px;
--vtl-size-4: 4px;
--vtl-size-8: 8px;
--vtl-size-12: 12px;
--vtl-size-14: 14px;
--vtl-size-16: 16px;
--vtl-size-20: 20px;
--vtl-size-24: 24px;
--vtl-size-32: 32px;
--vtl-size-40: 40px;
--vtl-size-96: 96px;
--vtl-size-full: 9999px;
--vtl-font-weight-400: 400;
--vtl-font-weight-600: 600;
--vtl-line-height-140: 1.4;
--vtl-border-radius-full: var(--vtl-size-full);
--vtl-color-bg-fill-default-on-light: var(--vtl-neutral-100);
--vtl-color-bg-fill-inverse-on-light: var(--vtl-neutral-01);
--vtl-color-text-disable-on-light: var(--vtl-neutral-70);
--vtl-color-text-on-bg-fill-on-light: var(--vtl-neutral-01);
--vtl-color-icon-default-on-light: var(--vtl-neutral-100);
--vtl-color-text-default-on-dark: var(--vtl-neutral-01);
--vtl-color-icon-default-on-dark: var(--vtl-neutral-01);
--vtl-space-2: var(--vtl-size-2);
--vtl-space-4: var(--vtl-size-4);
--vtl-space-8: var(--vtl-size-8);
--vtl-space-12: var(--vtl-size-12);
--vtl-space-16: var(--vtl-size-16);
--vtl-space-20: var(--vtl-size-20);
--vtl-space-24: var(--vtl-size-24);
--vtl-space-32: var(--vtl-size-32);
--vtl-space-40: var(--vtl-size-40);
--vtl-space-96: var(--vtl-size-96);
--vtl-font-size-14: var(--vtl-size-14);
}


{% endstyle %}

<!-- --UUID-14a1bc53-- -->

{%- liquid
	assign loading = "lazy"
	assign fetchpriority = "auto"
	assign preload = false
	assign icon_sizes = section.settings.icon_size | append: "px"

	if section.index == 1
		assign loading = "eager"
		assign fetchpriority = "high"
		assign preload = true
	endif
-%}

<section
	class="
		Vtls-{{ section.id | handle }} VtlsRotatingBarIcons
		VtlsRotatingBarIcons--backgroundStyle-{{ section.settings.section_background }}
		VtlsRotatingBarIcons--height-{{ section.settings.rotating_bar_height }}
		VtlsRotatingBarIcons--textSize-{{ section.settings.text_size }}
		VtlsRotatingBarIcons--textStyle-{{ section.settings.text_style }}
	"
>
	<div
		class="
			VtlsRotatingBarIconsContainer
			VtlsRotatingBarIconsContainer--height-{{ section.settings.rotating_bar_height }}
			{% if request.visual_preview_mode %}VtlsRotatingBarIconsContainer--previewStyles{% endif %}
		"
	>
		{% if section.settings.rotating_bar_layout == "slider" %}
			<rotating-icons-bar-slider class="VtlsRotatingBarIconsSliderContainer">
				{%- if section.blocks.size > 1 -%}
					<button
						class="VtlsRotatingBarIconsSliderContainer__Btn VtlsRotatingBarIconsSliderContainer__Btn--prev"
						aria-controls="announcement-bar"
						aria-label="Previous"
					>
						<svg width="18" height="19" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M12.375 2.75L5.625 9.5L12.375 16.25" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</button>
				{%- endif -%}
				<div class="VtlsRotatingBarIconsSlider VtlsRotatingBarText--textStyle-{{ section.settings.text_style }}">
					{% for block in section.blocks %}
						{% capture vtls_icon %}
                      {% case block.settings.icon %}
