							{%- liquid
								assign text_wrapper_ticker = "span"
									if block.settings.text_link != blank
										assign text_wrapper_ticker = "a"
									endif
									assign icon_ticker = block.settings.icon
									assign font_awesome_ticker = block.settings.font_awesome
									assign custom_icon_ticker = block.settings.custom_icon
								-%}
								{%- if block.settings.text_alternative_font -%}
									<style>
										{{- block.settings.text_font | font_face: font_display: 'swap' -}}
									</style>
								{%- endif -%}
								{%- capture text_css_vars_ticker -%}
									--text-font: {{- block.settings.text_font.family -}};
									{%- if block.settings.change_icon_color and block.settings.block_icon_color != blank and block.settings.block_icon_color != 'transparent' -%}
										--block-icon-color: {{- block.settings.block_icon_color -}};
									{%- endif -%}
									{%- if block.settings.change_text_color and block.settings.block_text_color != blank and block.settings.block_text_color != 'transparent' -%}
										--block-text-color: {{- block.settings.block_text_color -}};
									{%- endif -%}
								{%- endcapture -%}
								<div
									class="VtlsRotatingBarIconsTicker__Item"
									style="{{- text_css_vars_ticker | strip_newlines | escape -}}"
									{{ block.shopify_attributes }}
								>
									{%- if block.settings.icon_type == "icon" -%}
										{%- if font_awesome_ticker != blank -%}
											{% unless content_for_header contains "font-awesome" %}
												<link
													rel="stylesheet"
													href="https://use.fontawesome.com/releases/v5.15.4/css/all.css"
													integrity="sha384-DyZ88mC6Up2uqS4h/KRgHuoeGwBcD4Ng9SiP4dIRy0EXTlnuz47vAwmeGwVChigm"
													crossorigin="anonymous"
												>
											{% endunless %}
											<div class="VtlsRotatingBarIconsTicker__Icon">
												{{ font_awesome_ticker }}
											</div>
										{%- elsif icon_ticker != "none" -%}
											<div class="VtlsRotatingBarIconsTicker__Icon">
												{{ vtls_icon_ticker }}
											</div>
										{%- endif -%}
									{%- elsif block.settings.icon_type == "upload" -%}
										{%- if custom_icon_ticker != blank -%}
											<div class="VtlsRotatingBarIconsTicker__Icon">
												{{-
													custom_icon_ticker
													| image_url: width: custom_icon_ticker.width
													| image_tag:
														sizes: icon_sizes,
														widths: "30, 40, 60, 80, 100, 200, 400, 600",
														fetchpriority: fetchpriority,
														loading: loading,
														preload: preload
												-}}
											</div>
										{%- else -%}
											<div class="VtlsRotatingBarIconsTicker__Icon VtlsRotatingBarIconsTicker__IconDefault">
												<img
													src="data:image/webp;base64,"
													alt="Placeholder icon"
													width="520"
													height="520"
												>
											</div>
										{%- endif -%}
									{%- endif -%}
									{%- if block.settings.title != blank -%}
										<{{ text_wrapper_ticker }}
											href="{{ block.settings.text_link }}"
											class="
												VtlsRotatingBarIconsTicker__Text VtlsRotatingBarText
												{% if block.settings.text_alternative_font == true %}VtlsRotatingBarText--alternativeFont{% endif %}
											"
										>
											{{ block.settings.title }}
										</{{ text_wrapper_ticker }}>
									{%- endif -%}
								</div>
							{% endfor %}
						</div>
					{%- endfor -%}
				</vtls-rotating-icons-ticker>
			</div>
		{% endif %}
	</div>
</section>

{% schema %}
{
	"name": "🧡 Rotating & Icons",
	"settings": [
		{
			"type": "header",
			"content": "General"
		},
		{
			"type": "select",
			"id": "rotating_bar_layout",
			"label": "Bar layout",
			"options": [
				{
					"value": "slider",
					"label": "Slider"
				},
				{
					"value": "auto-rotating",
					"label": "Auto-rotate"
				}
			],
			"default": "auto-rotating"
		},
		{
			"type": "select",
			"id": "icon_alignment",
			"label": "Icon alignment",
			"visible_if": "{{ section.settings.rotating_bar_layout == 'slider' }}",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "left"
		},
		{
			"type": "select",
			"id": "rotating_bar_speed",
			"label": "Rotate speed",
			"visible_if": "{{ section.settings.rotating_bar_layout == 'auto-rotating' }}",
			"options": [
				{
					"value": "120",
					"label": "Slow"
				},
				{
					"value": "70",
					"label": "Medium"
				},
				{
					"value": "50",
					"label": "Fast"
				}
			],
			"default": "120"
		},
		{
			"type": "range",
			"id": "space_between_icons",
			"min": 24,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Space between icon blocks",
			"visible_if": "{{ section.settings.rotating_bar_layout == 'auto-rotating' }}",
			"default": 48
		},
		{
			"type": "select",
			"id": "rotating_bar_height",
			"label": "Bar height",
			"options": [
				{
					"value": "small",
					"label": "Small"
				},
				{
					"value": "medium",
					"label": "Medium"
				},
				{
					"value": "large",
					"label": "Large"
				}
			],
			"default": "medium"
		},
		{
			"type": "header",
			"content": "Text"
		},
		{
			"type": "select",
			"id": "text_size",
			"label": "Text size",
			"options": [
				{
					"value": "14",
					"label": "Small"
				},
				{
					"value": "16",
					"label": "Medium"
				},
				{
					"value": "20",
					"label": "Large"
				}
			],
			"default": "16"
		},
		{
			"type": "select",
			"id": "text_style",
			"label": "Text style",
			"options": [
				{
					"value": "regular",
					"label": "Regular"
				},
				{
					"value": "bold",
					"label": "Bold"
				}
			],
			"default": "regular"
		},
		{
			"type": "color",
			"id": "text_color",
			"label": "Text color",
			"default": "#ffffff"
		},
		{
			"type": "header",
			"content": "Icon"
		},
		{
			"type": "color",
			"id": "icon_color",
			"label": "Icon color",
			"default": "#ffffff",
			"info": "Does not apply to uploaded custom icons."
		},
		{
			"type": "range",
			"id": "icon_size",
			"min": 12,
			"max": 120,
			"step": 2,
			"unit": "px",
			"label": "Icon size",
			"default": 24
		},
		{
			"type": "header",
			"content": "Design"
		},
		{
			"type": "select",
			"id": "section_background",
			"label": "Section background",
			"options": [
				{
					"value": "color",
					"label": "Color"
				},
				{
					"value": "gradient",
					"label": "Gradient"
				}
			],
			"default": "color"
		},
		{
			"type": "color",
			"id": "rotating_bar_background",
			"label": "Background color",
			"default": "#222222",
			"visible_if": "{{ section.settings.section_background == 'color' }}"
		},
		{
			"type": "color_background",
			"id": "section_gradient",
			"label": "Background gradient",
			"default": "linear-gradient(to right, #fed951, #ff46c7)",
			"visible_if": "{{ section.settings.section_background == 'gradient' }}"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "range",
			"id": "top_margin",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Top margin (desktop)",
			"default": 0
		},
		{
			"type": "range",
			"id": "bottom_margin",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Bottom margin (desktop)",
			"default": 0
		},
		{
			"type": "range",
			"id": "top_margin_mobile",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Top margin (mobile)",
			"default": 0
		},
		{
			"type": "range",
			"id": "bottom_margin_mobile",
			"min": 0,
