					{%- liquid
						assign text_wrapper = "span"
						if block.settings.text_link != blank
								assign text_wrapper = "a"
							endif
						-%}
						{%- if block.settings.text_alternative_font -%}
							{%- liquid
								assign body_font_bold = block.settings.text_font | font_modify: "weight", "bold"
								assign body_font_italic = block.settings.description_font | font_modify: "style", "italic"
								assign body_font_bold_italic = body_font_bold | font_modify: "style", "italic"
							%}
							<style>
								{{- block.settings.text_font | font_face: font_display: 'swap' -}}
								{{ body_font_bold | font_face: font_display: 'swap' }}
								{{ body_font_italic | font_face: font_display: 'swap' }}
								{{ body_font_bold_italic | font_face: font_display: 'swap' }}
							</style>
						{%- endif -%}
						{%- capture text_css_variables -%}
							--text-font: {{- block.settings.text_font.family -}};
							{%- if block.settings.change_icon_color and block.settings.block_icon_color != blank and block.settings.block_icon_color != 'transparent' -%}
								--block-icon-color: {{- block.settings.block_icon_color -}};
							{%- endif -%}
							{%- if block.settings.change_text_color and block.settings.block_text_color != blank and block.settings.block_text_color != 'transparent' -%}
								--block-text-color: {{- block.settings.block_text_color -}};
							{%- endif -%}
						{%- endcapture -%}
						{%- liquid
							assign icon = block.settings.icon
							assign font_awesome = block.settings.font_awesome
							assign custom_icon = block.settings.custom_icon
						-%}
						<div
							class="VtlsRotatingBarIconsSlider__Slide"
							data-block-id="{{ block.id }}"
							style="{{- text_css_variables | strip_newlines | escape -}}"
							{{ block.shopify_attributes }}
						>
							<div class="VtlsRotatingBarIconsSlider__Content VtlsRotatingBarIconsSlider__Content--align-{{ section.settings.icon_alignment }}">
								{%- if block.settings.icon_type == "icon" -%}
									{%- if font_awesome != blank -%}
										{% unless content_for_header contains "font-awesome" %}
											<link
												rel="stylesheet"
												href="https://use.fontawesome.com/releases/v5.15.4/css/all.css"
												integrity="sha384-DyZ88mC6Up2uqS4h/KRgHuoeGwBcD4Ng9SiP4dIRy0EXTlnuz47vAwmeGwVChigm"
												crossorigin="anonymous"
											>
										{% endunless %}
										<div class="VtlsRotatingBarIconsSlider__Icon">
											{{ font_awesome }}
										</div>
									{%- elsif icon != "none" -%}
										<div class="VtlsRotatingBarIconsSlider__Icon">
											{{ vtls_icon }}
										</div>
									{%- endif -%}
								{%- elsif block.settings.icon_type == "upload" -%}
									{%- if custom_icon != blank -%}
										<div class="VtlsRotatingBarIconsSlider__Icon">
											{{-
												custom_icon
												| image_url: width: custom_icon.width
												| image_tag:
													sizes: icon_sizes,
													widths: "30, 40, 60, 80, 100, 200, 400, 600",
													fetchpriority: fetchpriority,
													loading: loading,
													preload: preload
											-}}
										</div>
									{%- else -%}
										<div class="VtlsRotatingBarIconsSlider__Icon VtlsRotatingBarIconsSlider__IconDefault">
											<img
												src="data:image/webp;base64,"
												alt="Placeholder icon"
												width="520"
												height="520"
											>
										</div>
									{%- endif -%}
								{%- endif -%}
								{%- if block.settings.title != blank -%}
									<{{ text_wrapper }}
										href="{{ block.settings.text_link }}"
										class="
											VtlsRotatingBarIconsSlider__Text VtlsRotatingBarText
											{% if block.settings.text_alternative_font == true %}VtlsRotatingBarText--alternativeFont{% endif %}
										"
									>
										{{ block.settings.title }}
									</{{ text_wrapper }}>
								{%- endif -%}
							</div>
						</div>
					{% endfor %}
				</div>
				{%- if section.blocks.size > 1 -%}
					<button
						class="VtlsRotatingBarIconsSliderContainer__Btn VtlsRotatingBarIconsSliderContainer__Btn--next"
						aria-controls="announcement-bar"
						aria-label="Next"
					>
						<svg width="18" height="19" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M5.625 2.75L12.375 9.5L5.625 16.25" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
